{
  "name": "zapdos",
  "version": "0.1.0",
  "private": true,
  "description": "1v1 competitive programming battles — progressive-unlock duels with ELO matchmaking.",
  "packageManager": "pnpm@9.7.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:realtime": "pnpm --filter web dev:realtime",
    "dev:matchmaker": "pnpm --filter web dev:matchmaker",
    "dev:finalizer": "pnpm --filter web dev:finalizer",
    "dev:bot": "pnpm --filter web dev:bot",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "start:realtime": "pnpm --filter web start:realtime",
    "start:matchmaker": "pnpm --filter web start:matchmaker",
    "start:finalizer": "pnpm --filter web start:finalizer",
    "start:bot": "pnpm --filter web start:bot",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @zapdos/db generate",
    "db:migrate": "pnpm --filter @zapdos/db migrate",
    "db:push": "pnpm --filter @zapdos/db push",
    "db:seed": "pnpm --filter @zapdos/db seed",
    "db:studio": "pnpm --filter @zapdos/db studio",
    "db:migrate:deploy": "pnpm --filter @zapdos/db migrate:deploy",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  },
  "dependencies": {}
}
