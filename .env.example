# ============================================================
# Zapdos — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- App ---
# Base URL of the Next.js app (used for auth callbacks, links, CORS).
APP_URL=http://localhost:3000
NODE_ENV=development
# Random 32+ char string. Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# --- Database (Postgres) ---
# Matches docker-compose.yml. For local dev you usually leave these as-is.
DATABASE_URL=postgresql://zapdos:zapdos_local@localhost:5432/zapdos?schema=public

# --- Redis ---
# Used for matchmaking queue, ephemeral live match state, and Socket.IO scaling.
# Include password in URL: redis://:password@host:port
REDIS_URL=redis://:zapdos_redis_pass@localhost:6379

# --- Judge0 CE (code execution sandbox) ---
# For local dev: http://localhost:2358 (Docker)
# For production: https://judge0-ce.p.rapidapi.com
JUDGE0_URL=http://localhost:2358
# Required for production (RapidAPI). Leave empty for local Docker.
JUDGE0_API_KEY=
# Max concurrent judge jobs per worker process.
JUDGE_CONCURRENCY=4

# --- Auth (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Google OAuth (optional) ---
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Match rules ---
# Battle duration in seconds (default 20 minutes).
MATCH_DURATION_SECONDS=1200
# Wrong-submission penalty, applied to per-problem score (floor 0).
WRONG_SUBMISSION_PENALTY=10
# ELO provisional-game threshold; K=K_PROVISIONAL until gamesPlayed >= this.
ELO_PROVISIONAL_GAMES=10
ELO_K_PROVISIONAL=40
ELO_K_ESTABLISHED=32
ELO_DEFAULT=1200

# --- Realtime (Socket.IO) ---
# Origin allowed for CORS on the realtime server.
REALTIME_CORS_ORIGIN=http://localhost:3000
# Internal URL the Next.js API routes use to POST /emit to the realtime server.
REALTIME_URL=http://localhost:3002
# Public URL the browser uses to open the Socket.IO connection.
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time.
NEXT_PUBLIC_REALTIME_URL=http://localhost:3002
