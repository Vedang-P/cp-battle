# ============================================================
# Zapdos — Production Environment Variables
# Fill in real values before deploying. NEVER commit this file.
# ============================================================

# --- App ---
APP_URL=https://your-app.onrender.com
NODE_ENV=production
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# --- Database (Neon Postgres) ---
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://xxx:yyy@ep-xxx.us-east-2.aws.neon.tech/zapdos?sslmode=require

# --- Redis (Upstash) ---
# Format: redis://default:password@host:port
REDIS_URL=redis://default:xxx@xxx.upstash.io:6379

# --- Judge0 CE (RapidAPI) ---
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-rapidapi-key-here
JUDGE_CONCURRENCY=4

# --- Auth (NextAuth) ---
NEXTAUTH_URL=https://your-app.onrender.com
NEXTAUTH_SECRET=change-me-to-a-long-random-string

# --- Match rules ---
MATCH_DURATION_SECONDS=1200
WRONG_SUBMISSION_PENALTY=10
ELO_PROVISIONAL_GAMES=10
ELO_K_PROVISIONAL=40
ELO_K_ESTABLISHED=32
ELO_DEFAULT=1200

# --- Realtime (Socket.IO) ---
REALTIME_CORS_ORIGIN=https://your-app.onrender.com
